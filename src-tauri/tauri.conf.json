{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReachNote",
  "version": "0.1.0",
  "identifier": "com.reachnote.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ReachNote",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "../assets/reachnote_brand_assets/png/icon/reachnote-symbol-transparent-32.png",
      "../assets/reachnote_brand_assets/png/icon/reachnote-symbol-transparent-128.png",
      "../assets/reachnote_brand_assets/png/icon/reachnote-symbol-transparent-512.png"
    ]
  }
}
