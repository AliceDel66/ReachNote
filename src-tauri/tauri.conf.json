{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReachNote",
  "version": "0.1.0",
  "identifier": "com.reachnote.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ReachNote",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "AI web capture for Notion",
    "longDescription": "ReachNote turns any link you browse into a structured Notion research card — local reading, AI analysis and Notion sync, all local-first.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
