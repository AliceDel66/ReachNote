# ReachNote · Notion 测试凭证模板
# ---------------------------------------------------------------------------
# 用法:复制本文件为 .env.notion(已被 .gitignore 忽略),填入真实值。
#   cp .env.notion.example .env.notion
# 安全:.env.notion 绝不提交;真实 token 绝不贴进聊天、PR、memory 或任何被 git 跟踪的文件。
# 自检:填好后运行  bash scripts/notion-smoke.sh
# ---------------------------------------------------------------------------

# 1) Internal Integration Token
#    https://www.notion.so/my-integrations → New integration → Internal → 复制 "Internal Integration Secret"
#    新格式以 ntn_ 开头;旧格式 secret_ 仍可用。
NOTION_TOKEN=ntn_REPLACE_ME

# 2) 测试 Database ID(32 位十六进制)
#    打开目标 database 的"整页"视图,从 URL 取:
#    https://www.notion.so/<workspace>/<DATABASE_ID>?v=...
#    带不带连字符都行。
NOTION_DATABASE_ID=REPLACE_ME

# 3)(可选)Data Source ID
#    仅在使用 Notion-Version 2025-09-03,或该 database 含多个 data source 时需要。
#    Notion app:打开 database 整页 → Database settings → Manage Data Sources → ⋯ → Copy data source ID
#    留空 → 自检脚本走 2022-06-28 + database_id 路径(单 data source 的新建 database 推荐)。
NOTION_DATA_SOURCE_ID=

# 4) API 版本
#    测试 MVP 推荐 2022-06-28(单 data source 可直接用 database_id)。
#    若 database 有多个 data source,改为 2025-09-03 并填上 NOTION_DATA_SOURCE_ID。
NOTION_VERSION=2022-06-28
