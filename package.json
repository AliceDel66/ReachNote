{
  "name": "reachnote",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "tauri": "tauri",
    "desktop:qa:build": "tauri build --debug --bundles app --no-sign --config src-tauri/tauri.qa.conf.json",
    "desktop:qa:smoke": "scripts/desktop-smoke-qa.sh"
  },
  "dependencies": {
    "@heroui/react": "^2.8.5",
    "@tauri-apps/api": "^2.8.0",
    "framer-motion": "^12.23.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.0",
    "@tailwindcss/vite": "^4.1.11",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
